# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=enrollment_agent

# OpenAI (optional — system works without it using mock responses)
OPENAI_API_KEY=sk-your-key-here

# OpenAI-compatible base URL (leave blank to use api.openai.com)
# Examples:
#   Azure OpenAI : https://<resource>.openai.azure.com/
#   Local proxy  : http://localhost:11434/v1
OPENAI_BASE_URL=

# Model to use for chat + copilot (default: gpt-4o-mini)
MODEL_NAME=gpt-4o-mini

